    chrClass['0'] = ALNUM:10;
    charSym['A'] = IDENT:26;
    chrClass['A'] = ALNUM:26;
    chrClass['_'] = ALNUM;
    charSym['\047'] = CHARCONST;
    charSym['_'] = IDENT;
    charSym['<'] = EXPROP;
    charSym['>'] = EXPROP;
    chrClass['+'] = PLUSOP;
    chrClass['-'] = MINUSOP;
    chrClass['*'] = MUL;
    chrClass['/'] = RDIVOP;
    chrClass['%'] = IMODOP;
