//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void inSymbol() { /* inSymbol */
var
    localBuf: char[131];
    tokenLen, tokenIdx: int;
    expSign: int;
    chain: irptr;
    expMultiple, expValue: real;
    curChar: char;
    numstr: word[17];
    expLiteral, expMagnitude: int;
    val: int;
    jb1473: int;
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void doCharConst(lim:char) {
// Set of characters that are not themselves after \
// 0123 4567 89:; <=>? @ABC DEFG HIJK LMNO PQRS TUVW XYZ
// ++++ ++++            ++    +         +    +  + +
//             11 1111 1111 2222 2222 2233 3333 3333 4444 4444
//             01 2345 6789 0123 4567 8901 2345 6789 0123 4567
const escSet = 0xFF0062022A00;
escMap = 007101412151113;
   for (tokenIdx = 6; tokenIdx <= 130; ++tokenIdx) {
       nextCH();
       if (CH == lim) {
           nextCH();
           return;
       }
       if (atEOL) {
2175:      error(59); /* errEOLNInStringLiteral */
            return;
        } else if (CH == BACKSLASH) {
            nextCH();
            if (CH-'0' IN escSet) {
                if (CH <= '7') {
                    expLiteral  =  0;
                    tokenLen  =  0;
                    do {
                        expLiteral  =  8*expLiteral + CH - '0';
                        ++tokenLen;
                        if ((tokenLen < 3) &&
                            ('0' <= *PASINPUT.data) && (*PASINPUT.data <= '7'))
                            nextCH();
                        else
                            break;
                    } while (true);
                    if (255 < expLiteral) {
                        error(errFirstDigitInCharLiteralGreaterThan3);
                    }
                    localBuf[tokenIdx]  =  expLiteral;
                } else {
                    val = card(escSet << (CH-'0')) - 1;
                    localBuf[tokenIdx]  =  (escMap >> (6*val)) & 077;
                }
            } else {
                goto 2233;
            }
        } else
2233:       with PASINFOR do {
                if (charEncoding == 3) {
                    if (ch < '*' || '\176' < CH)
                        curChar  =  '\0';
                    else {
                        curChar  =  iso2text[CH];
                    }
                } else {
                    curChar  =  CH;
                }
                localBuf[tokenIdx]  =  curChar;
            }
    }
    goto 2175
}
