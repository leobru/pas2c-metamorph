//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void formFileInit() {
var extFileP: *extfilerec;
    fileBase: tptr;
    fileSym: irptr;
    fileAddr, elemSize: int;
    if ((E48 >> S5) & optSflags) {
        formAndAlign(KUJ+I13);
        return;
    }
    form2Insn(KITS+13, KATX+SP);
    while (curExpr != NIL) {
        extFileP  =  pextf(curExpr->typ);
        fileSym  =  curExpr->id2;
        fileAddr  =  fileSym->value;
        fileBase  =  fileSym->typ.rep->base;
        elemSize  =  fileSym->typ.p.pad;
        if (fileAddr < 074000) {
            form1Insn(getValueOrAllocSymtab(fileAddr) +
                      KUTC + I7);
            fileAddr  =  0;
        }
        form3Insn(KVTM+I12 + fileAddr, KVTM+I10 + fileBufSize,
                  KVTM+I9 + elemSize);
        form1Insn(KVTM+I11 + fileBase.p.psize);
        if (extFileP == NIL) {
            form1Insn(KXTA);
        } else {
            curVal.i  =  extFileP->location;
            if (curVal.i == 512)
                curVal.i  =  extFileP->offset;
            form1Insn(KXTA+I8 + getFCSToffset());
        }
        formAndAlign(getHelperProc(69)); /*"P/CO"*/
        curVal.i  =  fileSym->id;
        form2Insn(KXTA+I8+getFCSToffset(), KATX+I12+26);
// File structure offset 25: a bit pattern to add after unpacking
// No need to do that for integers with zero exponent
        curExpr  =  curExpr->expr1;
    }
    form1Insn(getHelperProc(70)/*"P/IT"*/ + (KUJ-KVJM-I13));
    padToLeft();
} /* formFileInit */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
    rhsMode  =  true;
    if (errors && l3arg1z != SETREG || curExpr == NIL)
        return;
    if (! (l3arg1z IN [FORMOP, STOREAT9, DFLTWDTH, FILEINIT, PCKUNPCK]))
        genFullExpr(curExpr);
    switch (l3arg1z) {
    case DOIT:
        genOneOp();
        break;
    case SETREG: {
        with *insnList do {
            l3int3z  =  insnCount();
            helpExpr = malloc(sizeof(expr));
            helpExpr->expr1  =  withList;
            withList  =  helpExpr;
            helpExpr->op  =  NOOP;
            switch (st) {
            case stWORD:
                if (l3int3z == 0) {
                    l3int2z  =  14;
                } else {
                    l3var10z  =  auxRegs & freeRegs;
                    if (l3var10z != 0U) {
                        l3int2z  =  minel(l3var10z);
                    } else {
                        l3int2z  =  14;
                    }
                    if (l3int3z != 1) {
                        setAddrTo(l3int2z);
                        addToInsnList(KITA + l3int2z);
                        spillAcc(op37);
                    } else if (l3int2z != 14) {
                        setAddrTo(l3int2z);
                        genOneOp();
                    }
                    l3var11z  =  (E48 >> l3int2z) & (~[14]);
                    usedRegs &= ~l3var11z;
                    freeRegs &= ~l3var11z;
                    liveRegs |= l3var11z;
                }
                curVal.i  =  l3int2z;
                helpExpr->typ  =  curVal.tp;
                break;
            case stSLICE:
                curVal.i  =  14;
                helpExpr->typ  =  curVal.tp;
                break;
            case stPACKED:
                error(errVarTooComplex);
            } /* switch */
        } /* with */
        helpExpr->expr2  =  curExpr;
        break;
    } /* SETREG */
    case STORE:
        prepStore();
        genOneOp();
        break;
    case FORMOP:
        curInsnTemplate  =  curVal.i;
        formOperator(LOAD);
        curInsnTemplate  =  KXTA;
        break;
    case SETREG9:
        if (insnList->st != stWORD)
            error(errVarTooComplex);
        setAddrTo(9);
        genOneOp();
        break;
    case STOREAT9:
        l3int1z  =  curVal.i;
        genFullExpr(curExpr);
        prepLoad();
        if ((E48 >> 9) & insnList->regsused)
            error(errVarTooComplex);
        genOneOp();
        form1Insn(KATX+I9 + l3int1z);
        break;
    case SETREG12:
        setAddrTo(12);
        genOneOp();
        break;
    case DFLTWDTH:
        // Write routines need integer exponent on widths
        curVal.i  =  curVal.i | 0xD<<44;
        form1Insn(KXTA+I8 + getFCSToffset());
        break;
    case FRACWIDTH:
        prepLoad();
        prependToInsnList(macro + mcPUSH);
        genOneOp();
        break;
    case gen11: case gen12:
        setAddrTo(11);
        if (l3arg1z == gen12)
            prependToInsnList(macro + mcPUSH);
        genOneOp();
        usedRegs |= [12];
        break;
    case FILEACCESS:
        setAddrTo(12);
        genOneOp();
        formAndAlign(jumpTarget);
        break;
    case FILEINIT:
        formFileInit();
        break;
    case LOAD:
        prepLoad();
        genOneOp();
        break;
    case BRANCH:
        with *insnList do {
            noTarget  =  jumpTarget == 0;
            l3int3z  =  jumpTarget;
            if (ilm == ilCONST) {
                if (payload) {
                    jumpTarget  =  0;
                } else {
                    if (noTarget) {
                        formJump(&jumpTarget);
                    } else {
                        form1Insn(KUJ + jumpTarget);
                    }
                }
            } else {
                if ((curExpr->typ != boolType) && (!(curExpr->op IN
                    [SHLEFT..SETOR,GETELT..ALNUM]))) {
                    addToInsnList(KAEX);
                };
                direction  =  (16 in insnList->regsused);
                if (insnList->ilm == ilCOND &&
                    insnList->payload != 0) {
                    genOneOp();
                    if (direction) {
                        if (noTarget)
                            formJump(&l3int3z);
                        else
                            form1Insn(KUJ + l3int3z);
                        fixup(0, jumpTarget);
                        jumpTarget  =  l3int3z;
                    } else {
                        if (! noTarget) {
                            if (! putLeft)
                                padToLeft();
                            fixup(l3int3z, jumpTarget);
                        }
                    }
                } else {
                    if (insnList->ilm == ilLVAL) {
                        forValue  =  false;
                        prepLoad();
                        forValue  =  true;
                    }
                    genOneOp();
                    nextInsn  =  direction ? KU1A : KUZA;
                    if (noTarget) {
                        jumpType  =  nextInsn;
                        formJump(&l3int3z);
                        jumpType  =  KUJ;
                        jumpTarget  =  l3int3z;
                    } else {
                        form1Insn(nextInsn + l3int3z);
                    }
                }
            }
            break;
        } /* BRANCH */
    case PCKUNPCK:
        helpExpr  =  curExpr;
        curExpr  =  curExpr->expr1;
        formOperator(gen11);
        genFullExpr(helpExpr->expr2);
        if ((E48 >> 11) & insnList->regsused)
            error(44); /* errIncorrectUsageOfStandProcOrFunc */
        setAddrTo(12);
        genOneOp();
        arg1Type  =  helpExpr->expr2->typ;
        l3int3z  =  arg1Type.rep->aright - arg1Type.rep->aleft + 1;
        form2Insn((KVTM+I14) + l3int3z,
                  (KVTM+I10+64) - arg1Type.rep->pcksize);
        l3int3z  =  int(helpExpr->typ.rep);
        l3int1z  =  arg1Type.rep->perword;
        if (l3int3z == 72)           /* P/KC */
            l3int1z  =  1 - l3int1z;
        form1Insn(getValueOrAllocSymtab(l3int1z) + (KVTM+I9));
        l3int1z  =  KXTA;
        form1Insn(l3int1z);
        formAndAlign(getHelperProc(l3int3z));
        break;
   case LITINSN:
        with *insnList do {
            if (ilm != ilCONST)
                error(errNoConstant);
            if (insnList->typ.p.psize != 1)
                error(errConstOfOtherTypeNeeded);
            curVal.i  =  insnList->payload;
        }
    } /* switch */
} /* formOperator */
