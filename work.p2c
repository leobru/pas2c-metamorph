        } while (SY == COMMA);
        myrollup(int(boundary));
    } while (SY == SEMICOLON);
    if (SY != ENDSY)
        error(errBadSymbol);
    reset(F);
    while (! eof(F)) {
        putw(&FCST, *F.data);
        get(F);
