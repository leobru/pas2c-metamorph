void parseUnaryExpression;
var
    oper: operator;
    leftExpr: eptr;
{
    oper = NOOP;
    if (SY == NOTSY) {
        oper = (charClass == BITNEGOP) ? BITNEGOP : NOTOP;
        inSymbol();
    } else if (charClass IN [PLUSOP, MINUSOP, MUL, SETAND]) {
        if (charClass != PLUSOP)
            oper = charClass;
        inSymbol();
    }
    factor();
    if (oper != NOOP) {
        arg1Type = curExpr->typ;
        new(leftExpr);
        with leftExpr@ do {
            typ = arg1Type;
            expr1 = curExpr;
            switch (oper) {
            case MINUSOP:
                if (arg1Type == realType) {
                    leftExpr->op = RNEGOP;
                    leftExpr->typ = realType;
                } else if (typeCheck(arg1Type, intType)) {
                    leftExpr->op = INEGOP;
                    leftExpr->typ = intType;
                } else {
                    error(69); /* errUnaryMinusNeedRealOrInteger */
                    return;
                }
                break;
            case BITNEGOP:
                if (typeCheck(arg1Type, intType)) {
                    leftExpr->op = BITNEGOP;
                    leftExpr->typ = intType;
                } else {
                    error(62); /* errIntegerNeeded */
                    return;
                }
                break;
            case NOTOP:
                leftExpr->typ = boolType;
                if (arg1Type == boolType) {
                    leftExpr->op = NOTOP;
                } else if (arg1Type == intType) {
                    leftExpr->op = EQOP;
                    new(leftExpr->expr2);
                    leftExpr->expr2@ = [intType, GETENUM, 0U];
                } else {
                    error(errNeedOtherTypesOfOperands);
                    return;
                }
                break;
            case MUL:
                with leftExpr@ do {
                    if (arg1Type->k == kindPtr) {
                        typ = arg1Type->base;
                        op = DEREF;
                    } else if (arg1Type->k == kindFile) {
                        typ = arg1Type->base;
                        op = FILEPTR;
                    } else {
                        stmtName = 'unary*';
                        error(errWrongVarTypeBefore);
                    }
                }
            break;
            case SETAND:
                if (! (curExpr->op IN lvalOpSet))
                    error(27); /* errExpressionWhereVariableExpected */
                with leftExpr@ do {
                    typ = voidPtr;
                    op = STANDPROC;
                    expr1 = curExpr;
                    num2 = fnREF;
