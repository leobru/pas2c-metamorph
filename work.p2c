     /*8-17*/ sizes:        int[10];
       /*18*/ flags:        int;
};
    paseofcd:alfa;
//
// %%%%%%%%%%%% Libc functions %%%%%%%%%%%
//
int mapai(a:alfa); assembler;
void longjmp(jmpbuf, val: int); assembler;
int setjmp(jmpbuf: *int); assembler;
int setup(); assembler;
void rollup(addr: int); assembler;
void fopen(fcb: *ifcb; sizes, name: int); assembler;
void fclose(fcb: *ifcb); assembler;
void putw(f: *ifcb; i: int) {
    *f->data = i;
    put(*f);
}
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
//              PrintErrMsg               %
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void printErrMsg(errno: int) { /* PrintErrMsg */
typedef
    errtxt = __packed textchar[101];
    perrtxt = *errtxt;
var
    errptr: perrtxt;
    errtext: textchar[101];
    i: int;
    c: char;
//
    perrtxt pasmitxt(errno: int);
        fortran;
//
    char pasisoxt(txtchar: textchar);
        fortran;
//
    write(' ');
    if (errno >= 200)
        write('system=', errno:0);
    else {
        if (errno > 88)
            printErrMsg(86);
        else if (errno in [16..17, 20]) {
            if (errno == 20)
                errno  =  (sy == ident)*2 + 1;
            else
                write(curToken.i:0,' ');
        }
        errptr  =  pasmitxt(errno);
        unpack(*errptr, errtext, 0);
        for (i = 0; i <= 100; ++i) {
            c  =  pasisoxt(errtext[i]);
            if (c == '*')
                break;
            write(c);
        }
        write(' ');
        if (errno in [17, 22])
            if (errno == 17)
                write(errLine:0);
            else
                write(stmtName);
    }
    if (errno != 86)
        writeln;
} /* PrintErrMsg */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
//              printTextWord             %
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void printTextWord(val: int) { /* printTextWord */
//
    void PASTPR(val: int);
        extern;
//
    write(' ');
    PASTPR(val);
} /* printTextWord */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
//              makeStringType                %
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
tptr makeStringType() {
var res: tptr;
    if (maxSmallString >= strLen)
        return smallStringType[strLen];
    res.rep = malloc(offsetof(types, szArray));
    with *(res.rep) do {
        res.p.psize  =  (strLen + 5) / 6;
        res.p.bits  =  res.p.psize == 1 ? strLen << 3 : 0;
        base  =  charType;
        pck  =  true;
        perword  =  6;
        pcksize  =  8;
        aleft  =  1;
        aright  =  strLen;
    }
    res.p.pk  =  kindArray;
    return res;
} /* makeStringType */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
//              addToHashTab              %
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void addToHashTab(arg: irptr) {
    curVal.i  =  arg->id & hashMask;
    curVal.i = mapai(curVal.a);
    arg->next  =  symHash[curval.i];
    symHash[curval.i]  =  arg;
} /* addToHashTab */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void toFCST() {
    putw(&FCST, curVal.i);
    ++FcstCnt;
} /* toFCST */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
int addCurValToFCST() {
var
    low, high, mid: int;
    low  =  1;
    if (FcstCountTo500 == 0) {
        FcstCountTo500  =  1;
        constVals[1]  =  curVal.a;
        constNums[1]  =  FcstCnt;
    } else {
        high  =  FcstCountTo500;
        do {
            mid  =  (low + high) / 2;
            if (curVal.a == constVals[mid]) {
                return constNums[mid];
            }
            if (curval.a < constVals[mid])
                high  =  mid - 1;
            else
                low  =  mid + 1;
        } while (high >= low);
        if (FcstCountTo500 != 500) {
            high  =  curval.a < constVals[mid] ? mid : mid + 1;
            for (mid  =  FcstCountTo500; mid >= high; --mid) {
                low  =  mid + 1;
                constVals[low]  =  constVals[mid];
                constNums[low]  =  constNums[mid];
            }
            ++FcstCountTo500;
            constVals[high]  =  curVal.a;
            constNums[high]  =  FcstCnt;
        }
    }
    toFCST();
    return FcstCnt - 1;
} /* addCurValToFCST */
//
void error(errno: int);  forward;
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void endOfLine() {
var
    err, errPos, prevPos, listMode,
    startPos, lastErr: int;
    listMode  =  pasinfor.listMode;
    if (listMode || errsInLine) {
        write(' ', (lineStartOffset + PASINFOR.startOffset):5 oct,
              lineCnt:5, lineNesting:3, commentModeCH);
        startPos  =  13;
        do
            --linePos;
        while (lineBuf[linePos]  == ' ' && linePos >= 0);
        for (err = 0; err <= linePos; ++err) {
            write(linebuf[err]);
        }
        writeln;
        if (errsInLine) {
            write('*****':startPos, ' ':errMap[0]+1, '0');
            lastErr  =  errsInLine - 1;
            for (err = 1; err <= lastErr; ++err) {
                errPos  =  errMap[err];
                prevPos  =  errMap[err-1];
                if (errPos != prevPos) {
                    if (prevPos + 1 != errPos)
                        write(' ':(errPos-prevPos-1));
                    write(char(err + '0'));
                }
            }
            writeln;
            errsInLine  =  0;
            prevErrPos  =  0;
        }
    }
    lineStartOffset  =  moduleOffset;
    linePos  =  -1;
    ++lineCnt;
    if (eof(pasinput)) {
//        error(errEOFEncountered);
        writeln('EOF reached');
        halt;
    }
} /* endOfLine */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
//              storeObjWord              %
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void storeObjWord(insn: int) {
    objBuffer[objBufIdx]  =  insn;
    ++moduleOffset;
    if (objBufIdx == 1024) {
        error(49); /* errTooManyInsnsInBlock */
        objBufIdx  =  1;
    } else
        ++objBufIdx;
} /* storeObjWord */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
//              form1Insn                 %
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void form1Insn(arg: int) {
var
    insn, opcode: int;
    half1, half2: int;
    pos: int;
    insn  =  arg;
    opcode = insn & 077700000;
    if (opcode == KUJ) {
        if (prevOpcode == opcode)
            return; /* no use in UJ after UJ */
        if (putLeft && prevOpcode == 1) {
            pos  =  objBufIdx - 1;
            if ((objBuffer[pos] & (077700000 << 24)) == (KVJM+I13) << 24) {
                prevOpcode  =  opcode;
                half1 = (insn & 077777U) << 24;
                half2 = (objBuffer[pos] >> 24) & 077777U;
                objBuffer[pos]  =  (KVTM+I13) << 24 | KUJ | half1 | half2;
                return;
            }
        }
    } else if (prevOpcode > 1 && insn & 07777 &&
        (insn ^ prevInsn) == (KATX ^ KXTA) /* maybe ATX/XTA */) {
// Load after store; if the load reg/off is the same as the store,
// and the store was not a stack push, there is no need to do the read.
        if (prevInsn != KATX+SP &&
            (prevInsn & 02770000) == KATX /* but still ATX */)
            return; /* skip the XTA */
    }
    prevOpcode  =  opcode;
    prevInsn  =  insn;
    if (putLeft) {
        leftInsn  =  (insn & halfWord) << 24;
        putLeft  =  false;
    } else {
        putLeft  =  true;
        storeObjWord(leftInsn | (insn & halfWord));
    }
} /* form1Insn */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void form2Insn(i1, i2: int) {
    form1Insn(i1);
    form1Insn(i2);
} /* form2Insn */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void form3Insn(i1, i2, i3: int) {
    form2Insn(i1, i2);
    form1Insn(i3);
} /* form3Insn */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void disableNorm() {
    if (arithMode != 1) {
        form1Insn(disNormTemplate);
        arithMode  =  1;
    }
} /* disableNorm */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void formJump(arg: *int) {
var
    pos: int;
    isLeft: int;
    if (prevOpcode != KUJ) {
        pos  =  putLeft ? objBufIdx + 4096 : objBufIdx;
        isLeft  =  putLeft;
        form1Insn(jumpType + *arg);
        if (putLeft == isLeft)
            --pos;
        *arg  =  pos;
    }
} /* formJump */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void padToLeft() {
    if (!putLeft)
        form1Insn(KUTC);
    prevOpcode  =  0;
} /* padToLeft */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void formAndAlign(arg: int) {
    form1Insn(arg);
    padToLeft();
    prevOpcode  =  1;
} /* formAndAlign */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
int isCharArray(arg: tptr) {
    with *(arg.rep) do return arg.p.pk == kindArray && base == charType;
} /* isCharArray */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void putToSymTab(arg: int) {
    symTab[symTabPos]  =  arg;
    if (symTabPos == 075500) {
        error(50); /* errSymbolTableOverflow */
        symTabPos  =  074000;
    } else
        ++symTabPos;
} /* putToSymTab */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
int allocExtSymbol(sym: int) {
var i: int;
    if (curVal.i & halfWord) {
        for (i = 1; i <= longSymCnt; ++i)
            if (curVal.i == longSyms[i]) {
                return longSym[i];
            }
        ++longSymCnt;
        if (longSymCnt >= 90) {
            error(51); /* errLongSymbolOverflow */
            longSymCnt  =  1;
        }
        longSym[longSymCnt]  =  symTabPos;
        longSyms[longSymCnt]  =  curVal.i;
        sym  |=  020000000U;
    } else
        sym  |=  curVal.i;
    putToSymTab(sym);
    return symTabPos - 1;
} /* allocExtSymbol */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
int getHelperProc(l3arg1z: int) {
    if (helperMap[l3arg1z] == 0) {
        curVal.i  =  helperNames[l3arg1z];
        helperMap[l3arg1z]  =  allocExtSymbol(extSymMask);
    }
    return  helperMap[l3arg1z] + (KVJM+I13);
} /*getHelperProc */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
int allocSymtab(arg: int) {
var
    low, high, mid, ret: int;
    value: word;
    low  =  0;
    value.i  =  arg;
    if (symTabCnt == 0) {
        ret  =  symTabPos;
        symTabCnt  =  1;
        symTabArray[0].i  =  arg;
        symtbidx[0]  =  symTabPos;
    } else {
        high  =  symTabCnt;
        do {
            mid  =  (low + high) / 2;
            if (value == symTabArray[mid]) {
                return symtbidx[mid];
            }
            if ( value.a < symTabArray[mid].a)
                 high  =  mid;
            else
                 low  =  mid + 1;
        } while (high > low);
        ret  =  symTabPos;
        if (symTabCnt != 80) {
            high  =  (value.a < symTabArray[mid].a) ? mid : mid + 1;
            for (low  =  symTabCnt; low > high; --low) {
                mid  =  low - 1;
                symTabArray[low]  =  symTabArray[mid];
                symtbidx[low]  =  symtbidx[mid];
            }
            ++symTabCnt;
            symTabArray[high]  =  value;
            symtbidx[high]  =  symTabPos;
        }
    }
    putToSymTab(value.i);
    return ret;
} /* allocSymtab */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
int getFCSToffset() {
var
    offset: int;
    offset  =  addCurValToFCST();
    if (offset < 2048) {
        return offset;
    } else if (offset >= 4096)
        error(204);
    else {
        return allocSymtab(offset | 040000000U) - 070000;
    }
} /* getFCSToffset */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
int nrOfBits(value: int) {
    return 48 - minel(value & [7..47]);
} /* nrOfBits */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
tptr mkIntScl(bitWid: int) {
var
    res: tptr;
    if (bitWid < 1 || 40 < bitWid) {
        error(errNumberTooLarge);
        return intType;
    }
    res.rep = malloc(offsetof(types, szScalar));
    with *(res.rep) do {
        start = -1;
        enums = NIL;
        numen = 1 << bitWid;
    }
    res.p.psize  =  1;
    res.p.bits  =  bitWid;
    res.p.pk  =  kindScalar;
    return res;
} /* mkIntScl */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
int getValueOrAllocSymtab(value: int) {
    curVal.i  =  value & 077777;
    return (040000 >= curVal.i) ? curVal.i
        : allocSymtab((curVal.i | 040000000U) & halfWord);
} /* getValueOrAllocSymtab */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
// fixup -- address-fixup helper; see base.pas for full mode docs.
void fixup(mode, arg: int) {
var
    addr, insn, leftHalf: int;
    isLarge: int;
    work, offset: int;
    if (mode == 0) {
        padToLeft();
        curVal.i  =  moduleOffset;
1:      addr  =  curval.i & 077777U;
        leftHalf = curVal.i << 24;
        while (arg) {
            if (4096 < arg) {
                isLarge  =  true;
                arg  -=  4096;
            } else isLarge  =  false;
            insn  =  objBuffer[arg];
            if (isLarge) {
                curVal.i  = (insn >> 24) & 077777U;
                insn  =  insn & 07770000077777777U | leftHalf;
            } else {
                curVal.i  =  insn & 077777U;
                insn  =  insn & 07777777777700000U | addr;
            }
            objBuffer[arg]  =  insn;
            arg  =  curVal.i;
        }
        return;
    } else if (mode == 2) {
        form1Insn(KVTM+I14 + curVal.i);
        if (curVal.i == 074001)
            form1Insn(KUTM+I14 + FcstCnt);
        form3Insn(KITA+14, KASN + arg, KAOX+I7+1);
        form1Insn(KATX+I7+1);
        return;
    } else if (mode < -2) {
        arg  -=  curVal.i;
        offset  =  getFCSToffset();
        work  =  -mode;
        curVal.i  =  arg;
        arg  =  getFCSToffset();
        form3Insn(KATX+SP+1, KSUB+I8 + offset, work);
        form3Insn(KRSUB+I8 + arg, work, KXTA+SP+1);
        return;
    } else if (mode == -1) {
        form1Insn(KVTM+I14 + lineCnt);
        formAndAlign(getHelperProc(arg));
        return;
    }
    curVal.i  =  mode;
    goto 1;
} /* fixup */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void requiredSymErr(sym: symbol) {
    if (linePos != prevErrPos) {
        error(sym + 88);
    }
} /* requiredSymErr */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void readToPos80() {
    while (linePos < 80) {
        ++linePos;
        lineBuf[linePos]  =  *PASINPUT.data;
        if (linePos != 80)  get(PASINPUT);
    }
    endOfLine();
} /* readToPos80 */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void nextCH() {
    do {
        atEOL  =  eoln(PASINPUT);
        CH  =  *PASINPUT.data;
        get(PASINPUT);
        ++linePos;
        lineBuf[linePos]  =  CH;
    } while ((maxLineLen < linePos) && !atEOL);
} /* nextCH */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void parseComment() { /* parseComment */
var
    badOpt, flag: int;
    c: char;
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
int readOptVal(limit: int) {
var t:int;
    nextCH();
    t  =  0;
    while (('9' >= CH) && (CH >= '0')) {
        t  =  10 * t + CH - '0';
        nextCH();
        badOpt  =  false;
    }
    if (limit < t)  badOpt  =  true;
    return t;
} /* readOptVal */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void readOptFlag(res: *int) {
    nextCH();
    if (CH == '-' || CH == '+') {
        *res  =  CH == '+';
        badOpt  =  false;
    }
    nextCH();
} /* readOptFlag */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
    nextCH();
    if (CH == '=') {
        do {
        nextCH();
        badOpt  =  true;
        switch (CH) {
        case 'D':
            curVal.i = readOptVal(15);
            optSflags  =  optSflags & [0..40] | curVal.i & [41..47];
            break;
        case 'Y': readOptFlag(&allowCompat); break; // just for LINES STRUCTURE
        case 'E': readOptFlag(&declEntry); break;
        case 'S':
            curVal.i = readOptVal(8);
            if (curVal.i == 3)  lineCnt  =  1;
            else if (curVal.i in [4..8])
                optSflags  |=  E48 >> (curVal.i - 3);
            break;
        case 'F': readOptFlag(&checkFortran); break;
        case 'L': PASINFOR.listMode = readOptVal(3); break;
        case 'P': readOptFlag(&doPMD); break; // ignored
        case 'T': readOptFlag(&checkBounds); break; // ignored
        case 'A': charEncoding = readOptVal(3); break;
        case 'C': readOptFlag(&checkTypes); break;
        case 'M': readOptFlag(&fixMult); break;
        case 'B': fileBufSize = readOptVal(4); break;
        case 'K': heapSize = readOptVal(23); break;
        }
        if (badOpt) {
            error(54); /* errErrorInPseudoComment */
        }
        } while (CH == ',');
    }
    do {
        while (CH != '*') {
            c  =  commentModeCH;
            commentModeCH  =  '*';
            if (atEOL)
                endOfLine();
            nextCH();
            commentModeCH  =  c;
        }
        nextCH();
    } while (CH != '/');
    nextCH();
} /* parseComment */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
int skipSp() {
     while ((CH == ' ' || CH == '\t') && !atEOL)
         nextCH();
     if (atEOL) {
         endOfLine();
         nextCH();
         return true;
     }
     return false;
}
