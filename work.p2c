    pasinfor: struct {
        /*0*/ listMode:     int;
        /*1*/ errors:       *int;
        /*2*/ entryptr:     *entries;
        /*3*/ startOffset:  int;
      /*4-6*/ a0, a1, a4:   *charmap;
