    symbol = enum {
/*0B*/  IDENT,      INTCONST,   REALCONST,  CHARCONST,
        STRINGSY,   LPAREN,     LBRACK,     EXPROP,
/*10B*/ RPAREN,     RBRACK,     COMMA,      SEMICOLON,
