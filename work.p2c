    ident:      int;
    target: int;
};
//
numLabel = struct {
    id:         int;
    line:       int;
    offset:     int;
    defined:    int;
};
//
identrec = struct {
    id:     int;
    offset: int;
    next:   irptr;
    typ: tptr;
    cl: idclass;
    union {
        struct {};
        struct {list: irptr; value: int; szIdent: int};
        struct {maybeUnused: int;
                uptype: tptr;
                pckfield:  int;
                shift:     int;
                width:     int; szField: int};
        struct {low, high: int;
                argList, preDefLink: irptr;
                level, pos: int;
                flags: int;
                sigtyp: tptr; szRoutine: int};
        struct {sysnum: int; szSys: int};
    };
};
pextf = *extfilerec;
extfilerec = struct {
