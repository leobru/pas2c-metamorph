            if (arg1Type == realType) {
                curExpr = mkExpr(RNEGOP, realType, curExpr, NIL);
            } else if (typeCheck(arg1Type, intType)) {
                curExpr = mkExpr(INEGOP, intType, curExpr, NIL);
            } else {
                error(69); /* errUnaryMinusNeedRealOrInteger */
                return;
            }
            break;
        case BITNEGOP:
            if (typeCheck(arg1Type, intType)) {
                curExpr = mkExpr(BITNEGOP, intType, curExpr, NIL);
            } else {
                error(62); /* errIntegerNeeded */
                return;
            }
            break;
        case NOTOP:
            if (arg1Type == boolType) {
                curExpr = mkExpr(NOTOP, boolType, curExpr, NIL);
            } else if (arg1Type == intType) {
                curExpr = mkExpr(EQOP, boolType, curExpr, mkIntLit(0));
            } else {
                error(errNeedOtherTypesOfOperands);
                return;
            }
            break;
        case MUL:
            if (arg1Type.p.pk == kindPtr) {
                curExpr = mkExpr(DEREF, arg1Type.rep->base,
                                 curExpr, NIL);
            } else if (arg1Type.p.pk == kindFile) {
                curExpr = mkExpr(FILEPTR, arg1Type.rep->base,
                                 curExpr, NIL);
            } else {
                stmtName = 'unary*';
                error(errWrongVarTypeBefore);
            }
            break;
        case SETAND:
            if (! (curExpr->op IN lvalOpSet))
                error(27); /* errExpressionWhereVariableExpected */
            curExpr  =  mkExpr(STANDPROC, voidPtr, curExpr, eptr(fnREF));
            break;
        case INCROP:
        case DECROP:
            if (! (curExpr->op IN lvalOpSet)) {
                error(27); /* errExpressionWhereVariableExpected */
                return;
