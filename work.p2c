/*=l1,p-,t-,s8,y+,k9,l1*/
extern _output_, _child_, pasinput, pasinfor, paseofcd;
//
const
    boilerplate = ' PASCAL 2 C METAMORPHOSIS (2025)';
//
    fnSQRT  = 0;  fnSIN  = 1;  fnCOS  = 2;  fnATAN  = 3;  fnASIN = 4;
    fnLN    = 5;  fnEXP  = 6;  fnABS =  7;  fnTRUNC = 8;  fnSIZEOF = 9;
    /*   10   */  /*   11  */  /*   12  */  /*    13  */  fnEOF  = 14;
    fnREF   = 15; fnEOLN = 16; fnSETJMP = 17; fnROUND = 18; fnCARD = 19;
    fnMINEL = 20; fnABSI = 21;
//
    S3 = 0;
    S5 = 2;
    S6 = 3;
    NoPtrCheck = 4;
    NoStackCheck = 5;
//
    ASN64 = 0360100;
//
    errBooleanNeeded = 0;
    errIdentAlreadyDefined = 2;
    errNoIdent = 3;
    errNotAType = 4;
    errNoConstant = 6;
    errConstOfOtherTypeNeeded = 7;
    errTypeMustNotBeFile = 9;
    errNotDefined = 11;
    errBadSymbol = 12;
    errNeedOtherTypesOfOperands = 21;
    errWrongVarTypeBefore = 22;
    errUsingVarAfterIndexingPackedArray = 28;
    errTooManyArguments = 38;
    errNoCommaOrParenOrTooFewArgs = 41;
    errNumberTooLarge = 43;
    errVarTooComplex = 48;
    errEOFEncountered = 52;
    errFirstDigitInCharLiteralGreaterThan3 = 60;
//
    precNone = -1;  precAssign = 0;  precCond = 1;    precOr = 2;     precAnd = 3;
    precBitOr = 4;  precBitXor = 5;  precBitAnd = 6;
    precEq = 7;     precRel = 8;     precShift = 9;
    precAdd = 10;   precMul = 11;
//
    macro = 0100000000;
    mcJUMP = 2;
    mcACC2ADDR = 6;
    mcPOP = 4;
    mcPUSH = 5;
    mcMULTI = 7;
    mcADDSTK2REG = 8;
    mcADDACC2REG = 9;
    mcROUND = 11;
    mcMINEL = 15;
    mcPOP2ADDR = 19;
    mcCOND2INT = 20;
    mcPCKSTORE = 22;
    mcCARD = 23;
//
// Some locations are only used by runtime, here for reference
    ASCII0 =    04000007;
    E1 =        04000010;
    ZERO =      04000011;
    MULTMASK =  04000012;
    MAXREAL =   04000013;
    MANTISSA =  04000014;
    PASFUZZ =   04000015;       // 1.0e-6 for fuzzy comparison of reals (*=R+*)
    REAL1 =     04000016;
    MINUS1 =    04000017;
    E15TO1 =    04000020;
    PLUS1 =     04000021;
    BITS15 =    04000022;
    REAL05 =    04000023;
    ALLONES =   04000024;
    MSB =       04000025;
    E40TO7 =    04000026;       // mask for P/IN
    HEAPPTR =   04000027;
//
    KATX =      0000000;
//   KSTX =      0010000;
    KXTS =      0030000;
    KADD =      0040000;
    KSUB =      0050000;
    KRSUB =     0060000;
    KAMX =      0070000;
    KXTA =      0100000;
    KAAX =      0110000;
    KAEX =      0120000;
    KARX =      0130000;
    KAVX =      0140000;
    KAOX =      0150000;
    KDIV =      0160000;
    KMUL =      0170000;
    KAPX =      0200000;
    KAUX =      0210000;
    KACX =      0220000;
    KANX =      0230000;
    KYTA =      0310000;
    KASN =      0360000;
    KNTR =      0370000;
    KATI =      0400000;
//   KSTI =      0410000;
    KITA =      0420000;
    KITS =      0430000;
    KMTJ =      0440000;
    KJADDM =    0450000;
    KE74 =      0740000;
    KUTC =      02200000;
    KWTC =      02300000;
    KVTM =      02400000;
    KUTM =      02500000;
    KUZA =      02600000;
    KU1A =      02700000;
    KUJ =       03000000;
    KVJM =      03100000;
    KVZM =      03400000;
//   KV1M =      03500000;
    KVLM =      03700000;
//
    I7 =        034000000;      /* frame pointer */
    I8 =        040000000;      /* const pointer */
    I9 =        044000000;      /* temp register */
    I10 =       050000000;      /* temp register */
    I11 =       054000000;      /* temp register */
    I12 =       060000000;      /* temp register */
    I13 =       064000000;      /* link register */
    I14 =       070000000;      /* temp register */
    SP =        074000000;      /* stack pointer, reg 15 */
//
    halfWord  =  077777777U;
    all1 = 07777777777777777U;
    extSymMask  =  043000000U;
    maxLineLen = 130;
    /*=A3*/
    litForward  =  ' FORWARD';
    litFortran  =  ' FORTRAN';
    litOct  =  '     OCT';
    litOutput  =  '*OUTPUT*';
    litInput  =  ' *INPUT*';
    /*=A2*/
    FALSE  =  0U;
    TRUE  =  1U;
    E48 = 04000000000000000U;
    P_CP = 15;
    P_RC = 18;
    P_RR = 56;
    P_TR = 58;
    P_LDAR = 74;
type
    symbol = enum {
/*0B*/  IDENT,      INTCONST,   REALCONST,  CHARCONST,
        LTSY,       GTSY,       NOTSY,      LPAREN,
/*10B*/ LBRACK,     MULOP,      ADDOP,      RELOP,
        RPAREN,     RBRACK,     COMMA,      SEMICOLON,
/*20B*/ PERIOD,     ARROW,      COLON,      BECOMES,
        BEGINSY,    ENDSY,      CONSTSY,    TYPESY,
/*31B*/ VARSY,      FUNCSY,     VOIDSY,     ENUMSY,
        PACKEDSY,   ARRAYSY,    STRUCTSY,   FILESY,
/*40B*/ IFSY,       SWITCHSY,   WHILESY,    FORSY,
        WITHSY,     GOTOSY,     ELSESY,     OFSY,
/*50B*/ DOSY,       EXTERNSY,   BREAKSY,    CONTSY,
        CASESY,     DEFAULTSY,  NOSY
};
//
idclass = enum {
        TYPEID,     ENUMID,     ROUTINEID,  VARID,
        FORMALID,   FIELDID
};
//
setofsys = int; // set of symbol
//
operator = enum {
    SHLEFT,     SHRIGHT,
    SETAND,     SETXOR,     SETOR,
    MUL,        RDIVOP,     ANDOP,     IDIVOP,     IMODOP,
    PLUSOP,     MINUSOP,    OROP,       NEOP,       EQOP,
    LTOP,       GEOP,       GTOP,       LEOP,       INOP,
    IMULOP,     INTPLUS,    INTMINUS,   CONDOP,     ALTERN,
    badop31,    unused32,   ASSIGNOP,   GETELT,     GETVAR,
    op36,       op37,       GETENUM,    GETFIELD,   DEREF,
    FILEPTR,    op44,       ALNUM,      PCALL,      FCALL,
    TOREAL,     NOTOP,      INEGOP,     RNEGOP,     BITNEGOP,
    STANDPROC,  NOOP
};
//
opgen = enum {
    gen0,  STORE, LOAD,  FORMOP,  SETREG,
    SETREG9,  STOREAT9,  DOIT,  SETREG12,  DFLTWDTH,
    FRACWIDTH, gen11, gen12, FILEACCESS, FILEINIT,
    BRANCH, PCKUNPCK, LITINSN
};
//
// Flags for ops that can potentially be optimized if one operand is a constant
opflg = enum {
    opfCOMM, opfHELP, opfAND, opfOR, opfDIV, opfMOD, opfSHIFT,
    opfMULMSK, opfASSN
};
//
kind = enum {
    kindReal, kindScalar, kindPtr,
    kindArray, kindStruct, kindFile,
    kindCases
};
//
eptr = @expr;
tptr = @types;
irptr = @identrec;
//
textchar = int:6;
word = struct { switch int of
    0: {i: int};
    1: {r: real};
    3: {a: alfa};
    4: {t: __packed array[8] of textchar};
    7: {c: char};
    8: {cl: idclass};
    9: {tp: tptr};
};
//
oiptr = @oneinsn;
//
oneinsn  = struct {
    next: oiptr;
    mode, code, offset: int;
};
//
ilmode = enum {ilCONST, il1, ilVALINACC, il3};
state = enum {st0, st1, st2};
assoc = enum {
    leftAs,     rightAs
};
//
insnltyp  = struct {
    tail, head: oiptr;
    typ: tptr;
    regsused: int;
    ilm: ilmode;
    payload: int;
    disp: int;
    addrmd: int;
    st: state;
    width, shift: int
};
//
types = struct {
    size,
    bits:   int;
    k:      kind;
    switch kind of
    kindReal:   {};
    kindArray:  {abase,
                 rbase:     tptr;
                 pck:       int;
                 perword,
                 pcksize, aleft, aright:   int};
    kindScalar: {enums:     irptr;
                 numen,
                 start:     int};
    kindPtr:    {base:      tptr};
    kindFile:   {fbase:      tptr;
                 elsize:    int};
    kindStruct: {ptr1,
                 ptr2:      irptr;
                 flag,
                 pckrec:    int};
    kindCases:  {sel:       int;
                 first,
                 next:      tptr;
                 alt:       tptr}
};
//
charmap   = __packed array ['\000'..'\176'] of char;
textmap   = __packed array ['\052'..'\177'] of int:6;
//
four = array [1..4] of int;
entries   = array [42] of int;
//
expr = struct {
    typ:       tptr;
    op:        operator;
    switch operator of
    MUL:        {expr1, expr2: eptr};
    GETFIELD:   {typ1, typ2: tptr};
    NOTOP:      {id1, id2: irptr};
    STANDPROC:  {num1, num2: int};
};
//
kword = struct {
    w:      int;
    sym:    symbol;
    op:     operator;
    next:   @kword;
};
//
strLabel = struct {
    next:       @strLabel;
    ident:      int;
    target: int;
};
//
numLabel = struct {
    id:         int;
    line:       int;
    offset:     int;
    defined:    int;
};
//
identrec = struct {
    id:     int;
    offset: int;
    next:   irptr;
    typ: tptr;
    cl: idclass;
    switch idclass of
    TYPEID,
    VARID:  {};
    ENUMID,
    FORMALID:
            {list: irptr; value: int};
    FIELDID:
            {maybeUnused: int;
             uptype: tptr;
             pckfield:  int;
             shift:     int;
             width:     int};
    ROUTINEID:
            {low, high: int;
             argList, preDefLink: irptr;
             level, pos: int;
             flags: int
            };
};
pextf = @extfilerec;
extfilerec = struct {
    id:     int;
    offset: int;
    next:   pextf;
    location,
    line: int
};
NumberFormat = enum {DECIMAL, OCTAL, FULLWORD, HEX};
hashArray = array [128] of irptr;
//
var
    numFormat: NumberFormat;
    bigSkipSet, statEndSys, blockBegSys, statBegSys,
    skipToSet, lvalOpSet: setofsys;
    bool47z, bool48z, forValue: int;
    dataCheck: int;
    jumpType: int;
    jumpTarget: int;
    charClass: operator;
    SY, prevSY: symbol;
    savedObjIdx: int;
    FcstCnt: int;
    symTabPos: int;
    entryPtCnt: int;
    fileBufSize: int;
    withIter, withList: eptr;
    curInsnTemplate: int;
    linePos: int;
    prevErrPos: int;
    errsInLine: int;
    moduleOffset: int;
    lineStartOffset: int;
    curFrameRegTemplate: int;
    curProcNesting: int;
    totalErrors: int;
    lineCnt: int;
    bucket: int;
    strLen: int;
    heapCallsCnt: int;
    heapSize: int;
    arithMode: int;
    stmtName: alfa;
    keywordHashPtr: @kword;
    curVarKind: kind;
    curExternFile: pextf;
    commentModeCH: char;
    CH: char;
    prevInsn: int;
    debugLine: int;
    lineNesting: int;
    FcstCountTo500: int;
    objBufIdx: int;
    int92z, int93z, condLabCnt: int;
    prevOpcode: int;
    charEncoding: int;
    errLine: int;
    atEOL: int;
    checkTypes: int;
    isDefined, putLeft, readNext: int;
    errors: int;
    declExternal: int;
    rangeMismatch: int;
    doPMD: int;
    checkBounds: int;
    fixMult: int;
    abort: int;
    allowCompat: int;
    checkFortran: int;
    outputFile: irptr;
    inputFile: irptr;
    programObj: irptr;
    hashTravPtr: irptr;
    uProcPtr: irptr;
    externFileList: @extfilerec;
    baseType, typ121z: tptr;
    voidPtr: tptr;
    boolType: tptr;
    textType: tptr;
    intType: tptr;
    realType: tptr;
    charType: tptr;
    alfaType: tptr;
    arg1Type: tptr;
    arg2Type: tptr;
    numLabs: array [1..20] of numLabel;
    numLabTop: int;
    curToken: word;
    curVal: word;
    leftInsn: int;
    hashMask: int;
    curIdent: int;
    toAlloc: int;
    set145z: int;
    set146z:int;
    freeRegs:int;
    set148z: int;
    optSflags: int;
    uVarPtr: eptr;
    curExpr: eptr;
    insnList: @insnltyp;
    fileForOutput, fileForInput: @extfilerec;
    maxSmallString: int;
    smallStringType: array [2..6] of tptr;
    symTabCnt: int;
    symtabarray: array [80] of word;
    symtbidx: array [80] of int;
    intOpMap: array [MUL..MINUSOP] of operator;
    entryPtTable: entries;
    frameRestore: array [3..6] of four;
    indexreg: array [1..15] of int;
    opToInsn: array [SHLEFT..op44] of int;
    opToMode: array [SHLEFT..op44] of int;
    opFlags: array [SHLEFT..op44] of opflg;
    funcInsn: array [24] of int;
    frameRegTemplate: int;
    constRegTemplate: int;
    disNormTemplate: int;
    jb9999: int;
    lineBuf: array [130] of char;
    errMap: array [10] of int;
    chrClass: array ['\200'] of operator;
    kwordHash: array [128] of @kword;
    charSym: array ['\200'] of symbol;
    symHash, fieldHash: hashArray;
    helperMap: array [1..99] of int;
    helperNames: array [1..99] of int;
    opPrec: array [SHLEFT..ALTERN] of int;
    opAssoc: array [SHLEFT..ALTERN] of assoc;
//
    symTab: array [074000 .. 075500] of int;
    systemProcNames: array [23] of int;
    resWordName: array [27] of int;
    longSymCnt: int;
    longSym: array [1..90] of int;
    longSyms: array [1..90] of int;
    constVals: array [1..500] of alfa;
    constNums: array [1..500] of int;
    objBuffer: array [1..1024] of int;
    iso2text: array ['\052'..'\177'] of char;
    text2iso: __packed array ['\000'..'\077'] of char;
    maxHeap: int;
    fcst: file of int; /* last */
//
    pasinput: text;
//
    _child_: file of int;
//
    pasinfor: struct {
        /*0*/ listMode:     int;
        /*1*/ errors:       @int;
        /*2*/ entryptr:     @entries;
        /*3*/ startOffset:  int;
      /*4-6*/ a0, a1, a4:   @charmap;
        /*7*/ a3:           @textmap;
     /*8-17*/ sizes:        array [10] of int;
       /*18*/ flags:        int;
};
    paseofcd:alfa;
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
//              PrintErrMsg               %
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void printErrMsg(errno: int);
type
    errtxt = __packed array [101] of textchar;
var
    errptr: @errtxt;
    errtext: array [101] of textchar;
    i: int;
    c: char;
//
    function pasmitxt(errno: int): @errtxt;
        fortran;
//
    function pasisoxt(txtchar: textchar): char;
        fortran;
//
{ /* PrintErrMsg */
    write(' ');
    if (errno >= 200)
        write('system=', errno:0);
    else {
        if (errno > 88)
            printErrMsg(86);
        else if (errno in [16..18, 20]) {
            if (errno == 20)
                errno  =  (sy == ident)*2 + 1;
            else
                write(curToken.i:0,' ');
        }
        errptr  =  pasmitxt(errno);
        unpack(errptr@, errtext, 0);
        for (i = 0; i <= 100; i=i+1) {
            c  =  pasisoxt(errtext[i]);
            if (c == '*')
                break;
            write(c);
        }
        write(' ');
        if (errno in [17, 22])
            if (errno == 17)
                write(errLine:0);
            else
                write(stmtName);
    }
    if (errno != 86)
        writeln;
} /* PrintErrMsg */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
//              printTextWord             %
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void printTextWord(val: int);
//
    void PASTPR(val: int);
        extern;
//
{ /* printTextWord */
    write(' ');
    PASTPR(val);
} /* printTextWord */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
//              makeStringType                %
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
function makeStringType: tptr;
var res: tptr;
{
    if (maxSmallString >= strLen)
        return smallStringType[strLen];
    new(res, kindArray);
    with res@ do {
        size  =  (strLen + 5) / 6;
        bits  =  size == 1 ? strLen << 3 : 0;
        k  =  kindArray;
        base  =  charType;
        pck  =  true;
        perword  =  6;
        pcksize  =  8;
        aleft  =  1;
        aright  =  strLen;
        rbase  =  intType;
    }
    return res;
} /* makeStringType */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
//              addToHashTab              %
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void addToHashTab(arg: irptr);
{
    curVal.i  =  arg->id & hashMask;
    mapai(curval.a, curval.i);
    arg->next  =  symHash[curval.i];
    symHash[curval.i]  =  arg;
} /* addToHashTab */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void toFCST;
{
    write(FCST, curVal.i);
    FcstCnt  =  FcstCnt + 1;
} /* toFCST */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
function addCurValToFCST: int;
var
    low, high, mid: int;
{
    low  =  1;
    if (FcstCountTo500 == 0) {
        FcstCountTo500  =  1;
        constVals[1]  =  curVal.a;
        constNums[1]  =  FcstCnt;
    } else {
        high  =  FcstCountTo500;
        do {
            mid  =  (low + high) / 2;
            if (curVal.a == constVals[mid]) {
                return constNums[mid];
            }
            if (curval.a < constVals[mid])
                high  =  mid - 1;
            else
                low  =  mid + 1;
        } while (high >= low);
        if (FcstCountTo500 != 500) {
            high  =  curval.a < constVals[mid] ? mid : mid + 1;
            for (mid  =  FcstCountTo500; mid >= high; mid=mid-1) {
                low  =  mid + 1;
                constVals[low]  =  constVals[mid];
                constNums[low]  =  constNums[mid];
            }
            FcstCountTo500  =  FcstCountTo500 + 1;
            constVals[high]  =  curVal.a;
            constNums[high]  =  FcstCnt;
        }
    }
    toFCST();
    return FcstCnt - 1;
} /* addCurValToFCST */
//
void error(errno: int);  forward;
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void endOfLine;
var
    err, errPos, prevPos, listMode,
    startPos, lastErr: int;
{
    listMode  =  pasinfor.listMode;
    if (listMode || errsInLine) {
        write(' ', (lineStartOffset + PASINFOR.startOffset):5 oct,
              lineCnt:5, lineNesting:3, commentModeCH);
        startPos  =  13;
        do
            linePos  =  linePos-1;
        while (lineBuf[linePos]  == ' ' && linePos >= 0);
        for (err = 0; err <= linePos; err=err+1) {
            write(linebuf[err]);
        }
        writeln;
        if (errsInLine) {
            write('*****':startPos, ' ':errMap[0], '0');
            lastErr  =  errsInLine - 1;
            for (err = 1; err <= lastErr; err=err+1) {
                errPos  =  errMap[err];
                prevPos  =  errMap[err-1];
                if (errPos != prevPos) {
                    if (prevPos + 1 != errPos)
                        write(' ':(errPos-prevPos-1));
                    write(char(err + '0'));
                }
            }
            writeln;
            errsInLine  =  0;
            prevErrPos  =  0;
        }
    }
    lineStartOffset  =  moduleOffset;
    linePos  =  -1;
    lineCnt  =  lineCnt + 1;
    if (eof(pasinput)) {
        error(errEOFEncountered);
        longjmp(jb9999);
    }
} /* endOfLine */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
//              storeObjWord              %
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void storeObjWord(insn: int);
{
    objBuffer[objBufIdx]  =  insn;
    moduleOffset  =  moduleOffset + 1;
    if (objBufIdx == 1024) {
        error(49); /* errTooManyInsnsInBlock */
        objBufIdx  =  1;
    } else
        objBufIdx  =  objBufIdx + 1;
} /* storeObjWord */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
//              form1Insn                 %
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void form1Insn(arg: int);
var
    insn, opcode: int;
    half1, half2: int;
    pos: int;
{
    insn  =  arg;
    opcode = insn & 077700000;
    if (opcode == KUJ) {
        if (prevOpcode == opcode)
            return; /* no use in UJ after UJ */
        if (putLeft && prevOpcode == 1) {
            pos  =  objBufIdx - 1;
            if ((objBuffer[pos] & (077700000 << 24)) == (KVJM+I13) << 24) {
                prevOpcode  =  opcode;
                half1 = (insn & 077777U) << 24;
                half2 = (objBuffer[pos] >> 24) & 077777U;
                objBuffer[pos]  =  (KVTM+I13) << 24 | KUJ | half1 | half2;
                return;
            }
        }
    } else if (prevOpcode > 1 && insn & 07777 &&
        (insn ^ prevInsn) == (KATX ^ KXTA) /* maybe ATX/XTA */) {
// Load after store; if the load reg/off is the same as the store,
// and the store was not a stack push, there is no need to do the read.
        if (prevInsn != KATX+SP &&
            (prevInsn & 02770000) == KATX /* but still ATX */)
            return; /* skip the XTA */
    }
    prevOpcode  =  opcode;
    prevInsn  =  insn;
    if (putLeft) {
        leftInsn  =  (insn & halfWord) << 24;
        putLeft  =  false;
    } else {
        putLeft  =  true;
        storeObjWord(leftInsn | (insn & halfWord));
    }
} /* form1Insn */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void form2Insn(i1, i2: int);
{
    form1Insn(i1);
    form1Insn(i2);
} /* form2Insn */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void form3Insn(i1, i2, i3: int);
{
    form2Insn(i1, i2);
    form1Insn(i3);
} /* form3Insn */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void disableNorm;
{
    if (arithMode != 1) {
        form1Insn(disNormTemplate);
        arithMode  =  1;
    }
} /* disableNorm */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void formJump(arg: @int);
var
    pos: int;
    isLeft: int;
{
    if (prevOpcode != KUJ) {
