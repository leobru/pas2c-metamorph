/*20B*/ BEGINSY,    ENDSY,      CONSTSY,    TYPEDEFSY,
        VARSY,      TYPESY,     ENUMSY,
/*30B*/ PACKEDSY,   STRUCTSY,   IFSY,       SWITCHSY,
        WHILESY,    FORSY,      WITHSY,     GOTOSY,
/*40B*/ ELSESY,     DOSY,
        EXTERNSY,   BREAKSY,    CONTSY,     CASESY,
/*50B*/ DEFAULTSY,  UNIONSY,    NOSY
};
