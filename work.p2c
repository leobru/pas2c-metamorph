void parseUnaryExpression() {
var
    oper: operator;
    leftExpr: eptr;
    oper = NOOP;
    if (charClass IN [PLUSOP, MINUSOP, BITNEGOP, NOTOP, MUL, SETAND, INCROP, DECROP]) {
