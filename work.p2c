    checkSymAndRead(RPAREN);
    setBrCont();
    statement();
    brContTarget();
    if (loopExpr != NIL) {
        curExpr = loopExpr;
        formOperator(DOIT);
    }
    formJump(&toLoop);
    if (leave != 0) {
        padToLeft();
        fixup(0, leave);
    }
    brContTarget();
} /* forStatement */
