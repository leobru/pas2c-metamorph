//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void lexer() {
    switch (SY) {
    case IDENT: {
        curToken.i  = 0U;
        tokenLen  =  1;
        do {
            curVal.c  =  iso2text[CH];
            nextCH();
            if (8 >= tokenLen) {
                ++tokenLen;
                curToken.i  =  (curToken.i << 6) | curVal.i;
            }
        } while (chrClass[CH] == ALNUM);
        curVal.i  =  curToken.i & hashMask;
        bucket = mapAI(curVal.a);
        curIdent  =  curToken.i;
        keywordHashPtr  =  kwordHash[bucket];
        while (keywordHashPtr != NIL) {
            if (keywordHashPtr->w == curToken.i) {
                SY  =  keywordHashPtr->sym;
                charClass  =  keywordHashPtr->op;
                return;
            }
            keywordHashPtr  =  keywordHashPtr->next;
        }
        isDefined  =  false;
        SY  =  IDENT;
        switch (lookupMode) {
        case lookDef:
            hashTravPtr  =  symHash[bucket];
            while (hashTravPtr != NIL) {
                if (hashTravPtr->offset == curFrameRegTemplate) {
                    if (hashTravPtr->id != curIdent)
                        hashTravPtr  =  hashTravPtr->next;
                    else {
                        isDefined  =  true;
                        return;
                    }
                } else
                    return;
            }
            break;
        case lookWith:
        if (withList != NIL) {
            withIter  =  withList;
            chain  =  fieldHash[bucket];
            if (chain != NIL) {
                while (withIter != NIL) {
                    hashTravPtr  =  chain;
                    while (hashTravPtr != NIL) {
                        if ((hashTravPtr->id == curIdent)
                        && (hashTravPtr->uptype ==
                            withIter->expr2->typ))
                            return;
                        hashTravPtr  =  hashTravPtr->next;
                    }
                    withIter  =  withIter->expr1;
                }
            }
        }
        // FALLTHRU
        case lookUse:
            hashTravPtr  =  symHash[bucket];
            while (hashTravPtr != NIL) {
                if (hashTravPtr->id != curIdent)
                    hashTravPtr  =  hashTravPtr->next;
                else {
                    if (hashTravPtr->cl == TYPEID)
                        SY  =  TYPESY;
                    return;
                }
            }
            break;
        case lookField:
            hashTravPtr  =  fieldHash[bucket];
            while (hashTravPtr != NIL) {
                with *hashTravPtr do {
                    if ((id == curIdent) &&
                       (typ121z == uptype))
                        return;
                    hashTravPtr  =  next;
               }
           }
        }
        break;
    } /* IDENT */
    case INTCONST: { /*=m-*/
        SY  =  INTCONST;
        tokenLen  =  -1;
        do {
            ++tokenLen;
            if (tokenLen <= 16)
                numstr[tokenLen].i  =  CH - '0';
            else {
                error(55); /* errMoreThan16DigitsInNumber */
                tokenLen  =  1;
            }
            nextCH();
        } while (charSym[CH] == INTCONST);
        do {
            if ((numstr[0].i == 0) && (CH != '.')) {
                if (tokenLen == 0 && CH == 'X') {
                    /* Hex literal: 0Xhhh[U] */
                    numFormat = hex;
                    nextCH();
                    curToken.i = 0;
                    while (charSym[CH] == INTCONST
                       || ('A' <= CH) && (CH <= 'F')) {
                        curToken.i = curToken.i << 4 |
                            CH - (charSym[CH] == INTCONST ? 48 : 55);
                        nextCH();
                    };
                    if (CH == 'U')
                        nextCH();
                    return;
                };
                numFormat  =  OCTAL;
                if (CH == 'U') {
                    numFormat = FULLWORD;
                    nextCH();
                }
            } else {
                numFormat  =  DECIMAL;
                break;  /* octdec */
            }
            curToken.i  =  0;
            for (tokenIdx = 0; tokenIdx <= tokenLen; ++tokenIdx) {
                if (7 < numstr[tokenIdx].i) {
                    error(20); /* errDigitGreaterThan7 */
                }
                curToken.i = (curToken.i << 3) |
                    numstr[tokenIdx].i & 7;
            }
            return;
        } while (0);
        curToken.i  =  0;
        for (tokenIdx = 0; tokenIdx <= tokenLen; ++tokenIdx) {
            if (0xFFFFFFFFFF/10 >= curToken.i)
                curToken.i  =  10 * curToken.i +
                    numstr[tokenIdx].i;
            else {
                error(errNumberTooLarge);
                curToken.i  =  1;
            }
        }
        if (CH == 'U') {
            curToken.i &= [7..47];
            numFormat = FULLWORD;
            nextCH();
            return;
        }
        expMagnitude  =  0;
        if (CH == '.') {
            nextCH();
            if (CH == '.') {
                CH  =  ':';
                return;
            }
            curToken.r  =  curToken.i;
            SY  =  REALCONST;
            if (charSym[CH] != INTCONST) {
                error(56); /* errNeedMantissaAfterDecimal */
            } else
                do {
                    curToken.r  =  10.0*curToken.r + CH - '0';
                    --expMagnitude;
                    nextCH();
                } while (charSym[CH] == INTCONST);
        }
        if (CH == 'E') {
            if (expMagnitude == 0) {
                curToken.r  =  curToken.i;
                SY  =  REALCONST;
            }
            expSign  =  false;
            nextCH();
            if (CH == '+')
                nextCH();
            else if (CH == '-') {
                expSign  =  true;
                nextCH();
            }
            expLiteral  =  0;
            if (charSym[CH] != INTCONST) {
                error(57); /* errNeedExponentAfterE */
            } else
                do {
                    expLiteral  =  10 * expLiteral + CH - '0';
                    nextCH();
                } while (charSym[CH] == INTCONST);
            expMagnitude  =  expSign ? expMagnitude - expLiteral
                                     : expMagnitude + expLiteral;
        }
        if (expMagnitude) {
            expValue  =  1.0;
            expSign  =  expMagnitude < 0;
            expMagnitude  =  abs(expMagnitude);
            expMultiple  =  10.0;
            if (18 < expMagnitude) {
                expMagnitude  =  1;
                error(58); /* errExponentGreaterThan18 */
            }
            do {
                if (expMagnitude & 1U)
                    expValue *= expMultiple;
                expMagnitude /= 2;
                if (expMagnitude)
                    expMultiple *= expMultiple;
            } while (expMagnitude);
            if (expSign)
                curToken.r /= expValue;
            else
                curToken.r *= expValue;
        }
        return;
    } /* INTCONST */ /*=m+*/
    case CHARCONST: {
        doCharConst(CH);
        strLen  =  tokenIdx - 6;
        if (strLen == 0) {
           error(61); /* errEmptyString */
           strLen  =  1;
           goto 2320;
        } else if (strLen == 1) {
            SY  =  CHARCONST;
            tokenLen  =  1;
            curToken.i  =  0;
            unpck(localBuf[0], curToken.a);
            pck(localBuf[tokenLen], curToken.a);
            return;
        } else 2320: {
            curVal.a  =  '      ';
            SY  =  STRINGSY;
            unpck(localBuf[tokenIdx], curVal.a);
            pck(localBuf[6], curToken.a);
            curVal  =  curToken;
            if (strLen <= 6)
                return;
            else if (charEncoding == 3 && strLen == 8) {
                pack(localbuf, 6, curToken.t);
                curVal  =  curToken;
                SY = INTCONST;
                return;
            } else {
                curToken.i  =  FcstCnt;
                tokenLen  =  6;
                while (1) {
                    toFCST();
                    tokenLen += 6;
                    if (tokenIdx < tokenLen)
                        return;
                    pck(localBuf[tokenLen], curVal.a);
                }
            }
        }
        break;
    } /* CHARCONST */
    default:
        prevCH = CH;
        nextCH();
        switch (tok(prevCH << 8 | CH)) {
        /* Op-assigns: SY=BECOMES, charClass keeps the per-char op
           (PLUSOP/MINUSOP/MUL/RDIVOP/IMODOP/SETAND/SETOR/SETXOR) from
           chrClass[prevCH], so parsePrc can fold lhs = lhs op rhs. */
        case tok('+=') >> 32:
        case tok('-=') >> 32:
        case tok('*=') >> 32:
        case tok('/=') >> 32:
        case tok('%=') >> 32:
        case tok('&=') >> 32:
        case tok('|=') >> 32:
        case tok('^=') >> 32: SY = BECOMES; break;
        case tok('<=') >> 32: charClass = LEOP; break;
        case tok('<<') >> 32:
            charClass = SHLEFT; nextCH();
            if (CH == '=') { SY = BECOMES; nextCH(); }
            return;
        case tok('<:') >> 32: SY = BEGINSY; break;
        case tok('>>') >> 32:
            charClass = SHRIGHT; nextCH();
            if (CH == '=') { SY = BECOMES; nextCH(); }
            return;
        case tok('>=') >> 32: charClass = GEOP; break;
        case tok(':>') >> 32: SY = ENDSY; break;
        case tok('==') >> 32: SY = EXPROP; charClass = EQOP; break;
        case tok('!=') >> 32: charClass = NEOP; break;
        case tok('->') >> 32: SY = ARROW; break;
        case tok('--') >> 32: charClass = DECROP; break;
        case tok('++') >> 32: charClass = INCROP; break;
        case tok('||') >> 32: charClass = OROP; break;
        case tok('&&') >> 32: charClass = ANDOP; break;
        case tok('/*') >> 32: parseComment(); longjmp(jb1473, 1);
        case tok('//') >> 32: while (!atEOL) nextCH(); longjmp(jb1473, 1);
        case tok('..') >> 32: SY = COLON; break;
        default:
            if (prevCH == '.' && prevSY == ENDSY)
               dataCheck = true;
            return;
        } /* switch prevCH, CH */
        nextCH();
    } /* switch SY */
} /* lexer */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
        if (dataCheck) {
//            error(errEOFEncountered);
//            readToPos80();
            writeln('EOF reached');
            halt;
        }
        if(setjmp(&jb1473));
1473:   while(skipsp());
        hashTravPtr  =  NIL;
        SY  =  charSym[CH];
        charClass  =  chrClass[CH];
        lexer();
        prevSY  =  SY;
        commentModeCH  =  ' ';
        lookupMode  =  lookup2;
} /* inSymbol */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void skipToEnd() {
var
    sym: symbol;
    sym  =  SY;
    while ((CH != '\0') && ((sym != ENDSY) || (SY != PERIOD))) {
        sym  =  SY;
        inSymbol();
    }
    if (CH == 'D')
        while ((CH != '\0') && (SY != ENDSY))
            inSymbol();
    longjmp(jb9999, 1);
}
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void error {
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
    errors  =  abort  =  true;
    if ((linePos != prevErrPos && 9 >= errsInLine)
        || errno == 52)
     {
        write(' ');
        ++totalErrors;
        errMap[errsInLine]  =  linePos;
        ++errsInLine;
        prevErrPos  =  linePos;
        write('******', errno:0);
        printErrMsg(errno);
        if (60 < totalErrors) {
