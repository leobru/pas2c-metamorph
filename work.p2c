types = struct {
    union {
        struct {szReal: int};
        struct {abase:     tptr;
                pck:       int;
                perword,
                pcksize, aleft, aright: int; szArray: int};
        struct {enums:     irptr;
                numen,
                start:     int; szScalar: int};
        struct {base:      tptr; szPtr: int};
        struct {fbase:     tptr; szFile: int};
        struct {variants: tptr;
                fields:    irptr;
                flag,
                pckrec:    int; szStruct: int};
        struct {first,
                next:      tptr;
                alt:       tptr; szCases: int};
        struct {rresult:   tptr;
                rparams:   sigptr;
                rargc:     int;
                rflags:    int; szRtype: int};
    };
};
//
charmap   = __packed char['\0'..'\176'];
textmap   = __packed int:6['\52'..'\177'];
//
four = int[1..4];
entries   = int[42];
//
expr = struct {
    typ:       tptr;
    op:        operator;
    union {
        struct {expr1, expr2: eptr};
        struct {typ1, typ2: tptr};
        struct {id1, id2: irptr};
        struct {num1, num2: int};
    };
};
