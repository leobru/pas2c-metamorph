void caseStatement() { /* caseStatement */
typedef
    casechain = struct {
        next:   *casechain;
        value:  word;
        offset: int;
    };
var
    allClauses, curClause, clause, chain: *casechain;
    otherSeen: int;
    otherOffset: int;
    itemsEnded, goodMode: int;
    firstType, itemtype, exprtype: tptr;
    itemvalue: int;
    itemSpan: int;
    expected: word;
var startLine, decoder, endOfStmt: int;
    minValue, maxValue: word;

    startLine  =  lineCnt;
    parentExpression();
    exprtype  =  curExpr->typ;
    otherSeen  =  false;
    if (exprtype.p.pk == kindScalar)
        formOperator(LOAD);
    else
        error(25); /* errExprNotOfADiscreteType */
    disableNorm();
    decoder  =  0;
    endOfStmt  =  0;
    allClauses  =  NIL;
    formJump(&decoder);
    checkSymAndRead(BEGINSY);
    firstType.rep = NIL;
    goodMode  =  true;
    do {
        if (! (SY IN [SEMICOLON, ENDSY])) {
            padToLeft();
            arithMode  =  1;
            if (SY == DEFAULTSY) {
                if (otherSeen)
                    error(73); /* errCaseLabelsIdentical */
                inSymbol();
                otherSeen  =  true;
                otherOffset  =  moduleOffset;
            } else {
                if (SY != CASESY)
                    requiredSymErr(CASESY);
                expression();
                formOperator(LITINSN);
                itemvalue = curVal.i;
                itemType = insnList->typ;
                if (itemtype.rep != NIL) {
                    if (firstType.rep == NIL) {
                        firstType  =  itemtype;
                    } else {
                        if (! typeCheck(itemtype, firstType))
                            error(errConstOfOtherTypeNeeded);
                    }
                    clause = malloc(sizeof(casechain));
                    clause->value.i  =  itemvalue;
                    clause->offset  =  moduleOffset;
                    curClause  =  allClauses;
                    while (curClause != NIL) {
                        if (itemvalue == curClause->value.i) {
                            error(73); /* errCaseLabelsIdentical */
                            break;
                        } else if (itemvalue < curClause->value.i) {
                            break;
                        } else {
                            chain  =  curClause;
                            curClause  =  curClause->next;
                        }
                    }
                    if (curClause == allClauses) {
                        clause->next  =  allClauses;
                        allClauses  =  clause;
                    } else {
                        clause->next  =  curClause;
                        chain->next  =  clause;
                    }
                }
            }
            checkSymAndRead(COLON);
            while (!(SY in [CASESY,DEFAULTSY,ENDSY]))
                statement();
            goodMode  =  goodMode && (arithMode == 1);
        }
        itemsEnded  =  SY == ENDSY;
        if (SY == SEMICOLON)
            inSymbol();
    } while (! itemsEnded);
    if (SY != ENDSY) {
        requiredSymErr(ENDSY);
        stmtName  =  'SWITCH';
        reportStmtType();
    } else
        inSymbol();
    if (! typeCheck(firstType, exprtype)) {
        error(88); /* errDifferentTypesOfLabelsAndExpr */;
        return;
    }
    formJump(&endOfStmt);
    padToLeft();
    if (allClauses != NIL) {
        expected  =  allClauses->value;
        minValue  =  expected;
        curClause  =  allClauses;
        while (curClause != NIL) {
            if (expected == curClause->value) {
                maxValue  =  expected;
                ++expected.i;
                curClause  =  curClause->next;
            } else {
                itemSpan  =  34000;
                fixup(0, decoder);
                if (firstType.p.pk == kindScalar)
                    itemSpan  =  firstType.rep->numen;
                itemsEnded  =  itemSpan < 32000;
                if (itemsEnded) {
                    form1Insn(KATI+14);
                } else {
                    form1Insn(KATX+SP+1);
                }
                minValue.i  =  0;
                while (allClauses != NIL) {
                    if (itemsEnded) {
                        curVal.i  =  minValue.i - allClauses->value.i;
                        form1Insn(getValueOrAllocSymtab(curVal.i) +
                                  (KUTM+I14));
                        form1Insn(KVZM+I14 + allClauses->offset);
                        minValue  =  allClauses->value;
                    } else {
                        form1Insn(KXTA+SP+1);
                        curVal  =  allClauses->value;
                        form2Insn(KAEX + I8 + getFCSToffset(),
                                  KUZA + allClauses->offset);
                    }
                    allClauses  =  allClauses->next;
                }
                if (otherSeen)
                    form1Insn(KUJ + otherOffset);
                goto 16211;
            } /* if 16141 */
        } /* while 16142 */
        if (! otherSeen) {
            otherOffset  =  moduleOffset;
            formJump(&endOfStmt);
        }
        fixup(0, decoder);
        curVal  =  minValue;
        fixup(-(KU1A+otherOffset), maxValue.i);
        curVal.i  =  minValue.i / 2;
        form3Insn(ASN64+1, KATI+14, KYTA);
        curVal.i  =  moduleOffset + 1 - curVal.i;
        if (curVal.i < 040000) {
            curVal.i -= 040000;
            curVal.i  =  allocSymtab(041000000U | (curVal.i & 077777U));
        }
        form1Insn(KUJ+I14 + curVal.i);
        padToLeft();
        if (minValue.i % 2) {
            form1Insn(KUTC);
            decoder = KUJ;
        } else
            decoder = KUZA;
        while (allClauses != NIL) {
            form1Insn(decoder + allClauses->offset);
            allClauses  =  allClauses->next;
            decoder = KUZA ^ KUJ ^ decoder;
        }
        16211:
        fixup(0, endOfStmt);
        if (! goodMode)
           disableNorm();
    }
} /* caseStatement */
