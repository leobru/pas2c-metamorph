//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void markTypeSym() {
    if (SY == IDENT) {
        curVal.i  =  curIdent & hashMask;
        bucket = mapAI(curVal.a);
        hashTravPtr  =  symHash[bucket];
        while ((hashTravPtr != NIL) && (hashTravPtr->id != curIdent))
            hashTravPtr  =  hashTravPtr->next;
        if ((hashTravPtr != NIL) && (hashTravPtr->cl == TYPEID))
            SY  =  TYPESY;
    }
} /* markTypeSym */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
tptr parseTypeRef(skipTarget: setofsys) {
typedef
    pair = struct {
            first, second: int
    };
    pair7 = pair[1..7];
    caserec = struct {
            size, count: int;
            pairs: pair7;
    };
    rangeRec = struct {
            aleft, aright: int;
    };
    rangeList = rangeRec[1..20];
var
    isPacked: int;
    cond: int;
    cases: caserec;
    numBits, l3int22z, span, rangeCnt, curDim: int;
    curEnum, curField: irptr;
    arrayType, nestedType, tempType, curType: tptr;
