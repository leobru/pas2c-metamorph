//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
void initInsnTemplates;
var
    op: operator;
{
    for (idx = 1; idx < 16; idx=idx+1)
        indexreg[idx]  =  idx << 20;
    jumpType  =  KUJ;
    for (op = MUL; op <= ASSIGNOP; op=op+1) {
        opFlags[op]  =  opfCOMM;
        opToInsn[op]  =  0;
        if (op IN [MUL, RDIVOP, PLUSOP, MINUSOP]) {
            opToMode[op]  =  3;
        } else if (op IN [IDIVOP, IMODOP]) {
            opToMode[op]  =  2;
        } else if (op IN [IMULOP, INTPLUS, INTMINUS]) {
            opToMode[op]  =  1;
        } else {
            opToMode[op]  =  0;
        }
    }
    opToInsn[MUL]  =  KMUL;
    opToInsn[RDIVOP]  =  KDIV;
    opToInsn[IDIVOP]  =  17; /* C/DI */
    opToInsn[IMODOP]  =  11; /* C/MD */
    opToInsn[PLUSOP]  =  KADD;
    opToInsn[MINUSOP]  =  KSUB;
    opToInsn[IMULOP]  =  KMUL;
    opToInsn[SETAND]  =  KAAX;
    opToInsn[SETXOR]  =  KAEX;
    opToInsn[SETOR]  =  KAOX;
    opToInsn[INTPLUS]  =  KADD;
    opToInsn[INTMINUS]  =  KSUB;
    opToInsn[SHLEFT]  =  98;
    opToInsn[SHRIGHT]  =  99;
    opFlags[ANDOP]  =  opfAND;
    opFlags[IDIVOP]  =  opfDIV;
    opFlags[OROP]  =  opfOR;
    opFlags[IMULOP]  =  opfMULMSK;
    opFlags[IMODOP]  =  opfMOD;
    opFlags[ASSIGNOP]  =  opfASSN;
    opFlags[SHLEFT]  =  opfSHIFT;
    opFlags[SHRIGHT]  =  opfSHIFT;
    for (jdx = 0; jdx <= 6; jdx=jdx+1) {
        funcInsn[jdx]  =  0500000 + jdx;
