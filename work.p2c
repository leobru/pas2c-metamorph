opgen = enum {
    gen0,  STORE, LOAD,  FORMOP,  SETREG,
    SETREG9,  STOREAT9,  DOIT,  SETREG12,  DFLTWDTH,
    FRACWIDTH, gen11, gen12, FILEACCESS, FILEINIT,
    BRANCH, PCKUNPCK, LITINSN
};
//
// Flags for ops that can potentially be optimized if one operand is a constant
opflg = enum {
    opfCOMM, opfHELP, opfAND, opfOR, opfDIV, opfMOD, opfSHIFT,
    opfMULMSK, opfASSN
};
//
kind = enum {
    kindVoid, kindReal, kindScalar, kindPtr,
    kindArray, kindStruct, kindFile,
    kindCases, kindRoutine
};
//
eptr = *expr;
typptr = *types;
/*=s6*/
pckrep = __packed struct {
    rep:  typptr;
    bits: int:6;
    psize: int:15;
    pad:  int:8;
    pk:   kind;
};
tptr = struct {
    union {
        struct {rep: typptr};
        struct {p: pckrep};
    };
};
irptr = *identrec;
sigptr = *sigrec;
sigrec = struct {
    pclass: idclass;
    ptyp: tptr;
    next: sigptr
};
//
strhash = __packed struct {
        k   : int:6;
        hhh : int:18;
        ppp : *types;
        pad : int:6;
};

textchar = int:6;
word = struct {
    union {
        struct {i: int};
        struct {r: real};
        struct {a: alfa};
        struct {t: __packed textchar[8]};
        struct {c: char};
        struct {cl: idclass};
        struct {tp: tptr};
        struct {s: strhash};
    };
};
//
oiptr = *oneinsn;
//
oneinsn  = struct {
    next: oiptr;
    mode, code, offset: int;
};
//
ilmode = enum {ilCONST, ilLVAL, ilRVAL, ilCOND};
state = enum {stWORD, stSLICE, stPACKED};
