//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
int sameRoutineType(type1, type2: tptr) {
var
    p1, p2: sigptr;
    if (type1.rep->rargc != type2.rep->rargc ||
        ((type1.rep->rflags & [20,21,24,26]) !=
         (type2.rep->rflags & [20,21,24,26]))) {
        return false;
    }
    if (type1.rep->rresult != type2.rep->rresult &&
        (type1.rep->rresult.rep == NIL || type2.rep->rresult.rep == NIL ||
         ! typeCheck(type1.rep->rresult, type2.rep->rresult))) {
        return false;
    }
    p1  =  type1.rep->rparams;
    p2  =  type2.rep->rparams;
    while (p1 != NIL && p2 != NIL) {
        if (p1->pclass != p2->pclass)
            return false;
        if (p1->ptyp != p2->ptyp &&
            (p1->ptyp.rep == NIL || p2->ptyp.rep == NIL ||
             ! typeCheck(p1->ptyp, p2->ptyp))) {
            return false;
        }
        p1  =  p1->next;
        p2  =  p2->next;
    }
    return p1 == NIL && p2 == NIL;
} /* sameRoutineType */
//
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
    rangeMismatch  =  false;
    if (!checkTypes || type1 == type2)
1:      return true;
        with *(type1.rep) do {
            kind1  =  type1.p.pk;
            kind2  =  type2.p.pk;
            if (kind1 == kind2) {
                switch (kind1) {
                case kindReal:
                    /* empty */ break;
                case kindScalar:
                /* Two enums must be identical,
                 * all other combinations are okay.
                 */
                    if (type1.rep->enums == NIL || type2.rep->enums == NIL) {
                        goto 1;
                    }
                    break;
                case kindPtr:
                    if (type1 == voidPtr || type2 == voidPtr ||
                        typeCheck(type1.rep->base, type2.rep->base))
                        goto 1;
                    break;
                case kindArray:
                    span1  =  type1.rep->aright - type1.rep->aleft;
                    span2  =  type2.rep->aright - type2.rep->aleft;
                    if (typeCheck(type1.rep->base, type2.rep->base) &&
                       (span1 == span2) &&
                       (type1.rep->pck == type2.rep->pck) &&
                       !rangeMismatch) {
                        if (type1.rep->pck) {
                            if (type1.rep->pcksize == type2.rep->pcksize)
                                goto 1;
                        } else
                            goto 1;
                    }
                    break;
                case kindFile:
                    if (typeCheck(type1.rep->base, type2.rep->base))
                        goto 1;
                    break;
                case kindRoutine:
                    if (sameRoutineType(type1, type2))
                        goto 1;
                    break;
                } /* switch */
            }
            return false;
        }
} /* typeCheck */
