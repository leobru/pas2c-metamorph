    checkSymAndRead(SEMICOLON);
    padToLeft();
    toLoop = moduleOffset;
    leave = 0;
    if (SY != SEMICOLON) {
        readNext = false;
        expression();
        jumpTarget = 0;
        formOperator(BRANCH);
        leave = jumpTarget;
