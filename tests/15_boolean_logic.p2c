/*=p-,t-,s8,s9,y+,k9,l0*/
extern _output_;
//
var a, b: int;
{
  for (a = 0; a <= 1 ; a = a + 1) for (b = 0; b <= 1; b = b + 1) {
    if (a && b) {
        writeln(' ', a:1, ' AND ', b:1, ' is true');
    } else {
        writeln(' ', a:1, ' AND ', b:1, ' is false');
    };
    
    if (a || b) {
        writeln(' ', a:1, ' OR ', b:1, ' is true');
    } else {
        writeln(' ', a:1, ' OR ', b:1, ' is false');
    };
    
    if (! a) {
        writeln(' NOT ', a:1, ' is true');
    } else {
        writeln(' NOT ', a:1, ' is false');
    }
 }
}
.
