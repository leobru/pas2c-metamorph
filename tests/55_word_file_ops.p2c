/*=p-,t-,s8,y+,l0*/
extern _output_;
//
typedef fileblk = struct {
    data: *int;
    w1, w2, w3, w4, w5, w6, w7, w8, w9, w10,
    w11, w12, w13, w14, w15, w16, w17, w18, w19, w20,
    w21, w22, w23, w24, w25, w26, w27, w28, w29: int;
};
//
void fopen(fcb: *fileblk; packed, elsize, basesize, bufsize, name: int); assembler;
void fclose(fcb: *fileblk); assembler;
//
var
    f: fileblk;
    x, y: int;
//
{
    fopen(&f, 0, 48, 1, 1, 0);
    writeln('open ', f.w4:0, ' ', f.w18:0, ' ', f.w27:0, ' ', f.w2:0);

    rewrite(f);
    writeln('rewrite ', f.w4:0, ' ', f.w14:0, ' ', f.w2:0, ' ', f.w16:0);

    x = 1234;
    f.data = &x;
    put(f);
    writeln('put ', f.w2:0, ' ', f.w19:0, ' ', f.w27:0);

    reset(f);
    writeln('reset ', f.w4:0, ' ', f.w2:0, ' ', f.w19:0, ' ', f.w27:0);

    y = 0;
    f.data = &y;
    get(f);
    writeln('get ', y:0, ' ', f.w2:0, ' ', f.w19:0, ' ', f.w27:0);

    fclose(&f);
    writeln('close ', f.w4:0, ' ', f.w2:0, ' ', f.w19:0, ' ', f.w27:0);
}
.
