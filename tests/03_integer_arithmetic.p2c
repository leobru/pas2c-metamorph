/*=p-,t-,s8,y+,k9,l0*/
extern _output_;
//
var a, b, c: int;
{
    a = 10;
    b = 3;
    c = a + b;
    writeln(' 10 + 3 = ', c:0);
    c = a - b;
    writeln(' 10 - 3 = ', c:0);
    c = a * b;
    writeln(' 10 * 3 = ', c:0);
    c = a / b;
    writeln(' 10 / 3 = ', c:0);
    c = a % b;
    writeln(' 10 % 3 = ', c:0);
}
.
