/*=p-,t-,s8,y+,k9,l0*/
extern _output_;
//
var i, j: int;
{
    i = 0;
    while (i < 10) {
        i = i + 1;
        if (i == 3) continue;
        if (i == 7) break;
        writeln('w ', i:0);
    }
    writeln('after-w ', i:0);

    i = 0;
    do {
        i = i + 1;
        if (i == 2) continue;
        if (i == 5) break;
        writeln('d ', i:0);
    } while (i < 10);
    writeln('after-d ', i:0);

    i = 0;
    while (i < 3) {
        i = i + 1;
        j = 0;
        while (j < 5) {
            j = j + 1;
            if (j == 2) continue;
            if (j == 4) break;
            writeln('n ', i:0, ' ', j:0);
        }
    }
}
.
