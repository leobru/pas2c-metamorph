/*=p-,t-,s8,y+,k9,l0*/
extern _output_;
//
type
    intptr1 = *int;
    intptr2 = *int;
    arr1 = int[1..4];
    arr2 = int[1..4];
    pch1 = __packed char[1..6];
    pch2 = __packed char[1..6];
    mat1 = int[1..2][1..3];
    mat2 = int[1..2][1..3];
var
    p: intptr1;
    q: intptr2;
    a: arr1;
    b: arr2;
    c: pch1;
    d: pch2;
    m: mat1;
    n: mat2;
{
    p = malloc(1);
    q = malloc(1);
    *p = 7;
    *q = 9;
    a[2] = *p;
    b[2] = *q;
    c[3] = 'A';
    d[3] = 'B';
    m[1][3] = 13;
    n[2][1] = 21;
    writeln('cache ', a[2]:0, ' ', b[2]:0, ' ', c[3], ' ', d[3]);
    writeln('nest ', m[1][3]:0, ' ', n[2][1]:0);
}
.
