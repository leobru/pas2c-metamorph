/*=p-,t-,s8,y+,k9,l0*/
extern _output_;
//
var a, b, c, d: int;
{
    c = 42;
    a = b = c;
    writeln('two ', a:0, ' ', b:0, ' ', c:0);

    d = 7;
    a = b = c = d;
    writeln('four ', a:0, ' ', b:0, ' ', c:0, ' ', d:0);

    a = 0;
    b = (a = 5) + 1;
    writeln('embed ', a:0, ' ', b:0);

    a = b = 100;
    writeln('reuse ', a:0, ' ', b:0);
}
.
